[18.48, "o", "\u001b[2m# Any script that writes to stdout becomes a perception plugin.\u001b[0m\r\n"]
[18.78, "o", "\u001b[2m# The agent sees it. The agent decides what to do.\u001b[0m\r\n"]
[20.58, "o", "\r\n"]
[20.88, "o", "\u001b[1mmini-agent\u001b[0m \u2014 The AI agent that sees before it acts.\r\n"]
