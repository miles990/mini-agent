{
  "mcpServers": {
    "agent": {
      "type": "stdio",
      "command": "node",
      "args": [
        "dist/mcp-server.js"
      ],
      "env": {
        "AGENT_URL": "http://127.0.0.1:3001"
      }
    },
    "memory-db": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "mcp-server-sqlite-npx",
        "/Users/user/.mini-agent/instances/03bbc29a/memory-index.db"
      ]
    }
  }
}
