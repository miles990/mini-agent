# Mini-Agent Configuration
# Copy to .env and fill in your values

# Required: Instance ID (any short string)
MINI_AGENT_INSTANCE=my-agent

# Required: HTTP server port
PORT=3001

# Optional: Telegram notifications
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Optional: API authentication
# MINI_AGENT_API_KEY=

# Optional: Chrome CDP for web access
# CDP_PORT=9222

# Optional: LLM Provider — claude | codex | qwen (local oMLX)
# AGENT_PROVIDER=claude
# AGENT_FALLBACK=codex

# Optional: oMLX server (for qwen provider + pulse-reflex)
# OMLX_URL=http://localhost:8000
# OMLX_KEY=omlx-local
# OMLX_MODEL=Qwen3.5-9B-MLX-4bit
# OMLX_THINKING=false
